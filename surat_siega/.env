# ==================== APPLICATION ====================
APP_NAME="Arsip FIKOM"
APP_ENV=local
APP_KEY=base64:C/o/sJjHF2buxlG10nPjzpNASfNP45KslgqsYxHtJeQ=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost/fikomapp/surat_siega/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# ==================== SECURITY ====================
HASH_DRIVER=bcrypt
BCRYPT_ROUNDS=12

# ✅ Shared secret untuk verifikasi entry dari Dashboard Menu
# Generate: php -r "echo bin2hex(random_bytes(32));"
ENTRY_SHARED_SECRET=7bf5429f72beebd2f98b046e4527d46e83ba56f161e0508fb97fa33615b413f1

# ==================== LOGGING ====================
# Development: stack, Production: daily
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=30

# ==================== DATABASE ====================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=surat_fikom
DB_USERNAME=root
DB_PASSWORD=

# ==================== SESSION ====================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# ✅ Production: uncomment kedua baris berikut (wajib HTTPS)
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# ==================== DASHBOARD MENU ====================
DASHBOARD_MENU_URL=http://localhost:8000/dashboard

# ==================== BROADCAST & QUEUE ====================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ==================== CACHE ====================
CACHE_STORE=database
CACHE_PREFIX=

# ==================== REDIS (Optional) ====================
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==================== MAIL ====================
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS="noreply@siega.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==================== AWS (Optional) ====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==================== VITE ====================
VITE_APP_NAME="${APP_NAME}"

# ==================== PRODUCTION CHECKLIST ====================
# Sebelum deploy ke production, pastikan:
# 1. APP_ENV=production
# 2. APP_DEBUG=false
# 3. LOG_LEVEL=warning
# 4. SESSION_SECURE_COOKIE=true (wajib HTTPS)
# 5. SESSION_SAME_SITE=lax
# 6. SESSION_ENCRYPT=true
# 7. MAIL_MAILER=smtp (bukan log)
# 8. Generate APP_KEY baru: php artisan key:generate
# 9. Generate ENTRY_SHARED_SECRET: php -r "echo bin2hex(random_bytes(32));"
# 10. Set DB_PASSWORD yang kuat
# 11. Set APP_URL ke domain production (https://...)
# 12. Set DASHBOARD_MENU_URL ke URL yang benar
