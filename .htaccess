<IfModule mod_rewrite.c>
    RewriteEngine On

    # ============================================================
    # SECURITY: Redirect akses folder internal ke halaman 404
    # Menggunakan REDIRECT agar URL di address bar berubah
    # ============================================================
    
    # Redirect file .blade.php ke /not-found (PRIORITAS TERTINGGI)
    RewriteRule \.blade\.php$ /surat_siega/not-found [R=302,L]
    
    # Redirect folder sensitif ke /not-found (302 redirect)
    RewriteRule ^app(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^bootstrap(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^config(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^database(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^lang(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^resources(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^routes(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^storage(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^tests(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^vendor(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^node_modules(/.*)?$ /surat_siega/not-found [R=302,L]
    
    # Redirect file sensitif ke /not-found (302 redirect)
    RewriteRule ^\.env$ /surat_siega/not-found [R=302,L]
    RewriteRule ^\.env\..*$ /surat_siega/not-found [R=302,L]
    RewriteRule ^\.git(/.*)?$ /surat_siega/not-found [R=302,L]
    RewriteRule ^\.gitignore$ /surat_siega/not-found [R=302,L]
    RewriteRule ^\.gitattributes$ /surat_siega/not-found [R=302,L]
    RewriteRule ^\.editorconfig$ /surat_siega/not-found [R=302,L]
    RewriteRule ^composer\.(json|lock)$ /surat_siega/not-found [R=302,L]
    RewriteRule ^package(-lock)?\.json$ /surat_siega/not-found [R=302,L]
    RewriteRule ^artisan$ /surat_siega/not-found [R=302,L]
    RewriteRule ^phpunit\.xml$ /surat_siega/not-found [R=302,L]
    RewriteRule ^vite\.config\.js$ /surat_siega/not-found [R=302,L]
    RewriteRule ^README\.md$ /surat_siega/not-found [R=302,L]
    RewriteRule ^\.phpunit\.result\.cache$ /surat_siega/not-found [R=302,L]
    
    # Redirect file PHP di luar public ke /not-found
    RewriteCond %{REQUEST_URI} !^/surat_siega/public/
    RewriteRule \.php$ /surat_siega/not-found [R=302,L]

    # ============================================================
    # Redirect semua request ke folder public
    # ============================================================
    
    # Jika request sudah mengarah ke public, biarkan lewat
    RewriteCond %{REQUEST_URI} ^/surat_siega/public/
    RewriteRule ^ - [L]
    
    # Untuk request ke root, redirect ke public/index.php
    RewriteRule ^$ public/index.php [L]
    
    # Untuk semua request lainnya, teruskan ke public folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Tambahan: Blokir akses ke file backup dan log
<FilesMatch "\.(sql|log|bak|backup|old|orig|swp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
