# ==================== APPLICATION ====================
APP_NAME="Surat SIEGA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://your-domain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# ==================== SECURITY ====================
BCRYPT_ROUNDS=12

# ✅ Shared secret untuk verifikasi entry dari Dashboard Menu
# Generate: php -r "echo bin2hex(random_bytes(32));"
ENTRY_SHARED_SECRET=

# ==================== LOGGING ====================
# Development: stack/single, Production: daily
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

# ==================== DATABASE ====================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=surat_siega
DB_USERNAME=root
DB_PASSWORD=

# ==================== SESSION ====================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# ✅ Production: HTTPS wajib
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ==================== DASHBOARD MENU ====================
DASHBOARD_MENU_URL=https://dashboard-menu-domain.com/dashboard

# ==================== BROADCAST & QUEUE ====================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ==================== CACHE ====================
CACHE_STORE=database
CACHE_PREFIX=

# ==================== REDIS (Optional) ====================
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==================== MAIL ====================
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@siega.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==================== AWS (Optional) ====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==================== VITE ====================
VITE_APP_NAME="${APP_NAME}"

# ==================== PRODUCTION CHECKLIST ====================
# Sebelum deploy ke production, pastikan:
# 1. APP_ENV=production            ✅ Set di atas
# 2. APP_DEBUG=false               ✅ Set di atas
# 3. LOG_LEVEL=warning             ✅ Set di atas
# 4. SESSION_SECURE_COOKIE=true    ✅ Set di atas (wajib HTTPS)
# 5. SESSION_SAME_SITE=lax         ✅ Set di atas
# 6. SESSION_ENCRYPT=true          ✅ Set di atas
# 7. Generate APP_KEY baru:        php artisan key:generate
# 8. Generate ENTRY_SHARED_SECRET: php -r "echo bin2hex(random_bytes(32));"
# 9. Set DB_PASSWORD yang kuat
# 10. Set MAIL_MAILER=smtp dengan credentials SMTP
